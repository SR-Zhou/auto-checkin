{
  "login": {
    "url": "/login",
    "usernameSelector": "input.el-input__inner[placeholder=\"请输入学号/工号\"]",
    "passwordSelector": "input.el-input__inner[placeholder=\"请输入密码\"]",
    "submitSelector": "role=button[name=/登\\s*录/]"
  },
  "personal": {
    "url": "/group/today",
    "submitSequence": [
      { "selector": "text=个人打卡" },
      { "selector": ".checkin-btn:has(span:text-is(\"在校\"))", "waitMs": 1000, "force": true },
      { "selector": ".el-dialog__footer button:has-text(\"提交\")", "force": true }
    ],
    "successSelector": "text=打卡成功",
    "notInTimeWindowSelector": "text=当前不在打卡时间段内"
  },
  "leader": {
    "url": "/group/today",
    "alreadyDoneSelector": "text=今日打卡已提交至班委",
    "submitSelector": "role=button[name=/提交(本组打卡结果|至班委|本组结果)/]",
    "confirmSelector": "role=button[name=确认提交]",
    "successSelector": "text=提交成功"
  },
  "auth": {
    "loggedInSelector": "role=button[name=消息]",
    "loginFailedPattern": "信息有误|账号不存在|invalid|incorrect"
  }
}
