TARGET_URL=https://your-checkin-domain.example.com
CHECKIN_USERNAME=your_username
CHECKIN_PASSWORD=your_password
TIMEZONE=Asia/Shanghai

SITE_CONFIG_PATH=./config/site-config.json
SCREENSHOT_DIR=./runtime/screenshots
LOG_PATH=./runtime/app.log
MAX_ATTEMPTS=3
BACKOFF_MIN_MS=30000
BACKOFF_MAX_MS=90000
HEADLESS=true
BROWSER_TIMEOUT_MS=20000
BROWSER_SLOW_MO_MS=0
CHECKIN_ACTION_BUFFER_MS=1500
