[Unit]
Description=Daily Check-in Automation (One-shot)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=dawn
WorkingDirectory=/opt/daily-checkin
Environment=NODE_ENV=production
EnvironmentFile=/opt/daily-checkin/.env
ExecStart=/usr/bin/npm run start

[Install]
WantedBy=multi-user.target
